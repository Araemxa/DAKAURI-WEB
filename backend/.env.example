# Backend Environment Variables
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dakauri_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (untuk CORS)
FRONTEND_URL=http://localhost:5174
